generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// Application metadata (key-value JSON) — extend with domain models as needed.
model AppMetadata {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_metadata")
}
